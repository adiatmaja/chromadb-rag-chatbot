# =============================================================================
# RAG Product Search System - Environment Configuration
# =============================================================================
#
# Instructions:
# 1. Copy this file to .env
# 2. Update the values according to your environment
# 3. Never commit .env to version control

# =============================================================================
# LLM CONFIGURATION
# =============================================================================

# Base URL for LM Studio API endpoint
# For Docker: use http://host.docker.internal:1234/v1 to access host machine
# For local: use http://localhost:1234/v1
# For remote: use https://your-llm-server.com/v1
LLM_BASE_URL=http://host.docker.internal:1234/v1

# API key for LLM service
# For LM Studio: leave empty or use "lm-studio"
# For OpenAI: use your actual API key
LLM_API_KEY=

# Name of the model loaded in LLM service
# Must match the model name shown in LM Studio after loading
# Examples: qwen2.5-7b-instruct, llama-3.1-8b-instruct, qwen2.5-3b-instruct
LLM_MODEL_NAME=qwen2.5-7b-instruct

# Temperature for LLM sampling (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.0

# Maximum tokens for LLM response generation
LLM_MAX_TOKENS=1000

# =============================================================================
# VECTOR DATABASE CONFIGURATION
# =============================================================================

# Sentence transformer model for generating embeddings
# Options:
#   - paraphrase-multilingual-MiniLM-L12-v2 (recommended: multilingual, ~180MB, best for Indonesian/Javanese)
#   - all-MiniLM-L6-v2 (lightweight, ~80MB, English-primary)
#   - all-mpnet-base-v2 (more accurate, slower)
# WARNING: changing this requires re-running all indexing scripts to rebuild ChromaDB collections
EMBEDDING_MODEL_NAME=paraphrase-multilingual-MiniLM-L12-v2

# Name of the ChromaDB collection for products
COLLECTION_NAME=fmcg_products

# Name of the ChromaDB collection for FAQs
FAQ_COLLECTION_NAME=faq_collection

# Name of the ChromaDB collection for intents
INTENT_COLLECTION_NAME=intent_collection

# Number of top similar items to retrieve from vector search
RETRIEVAL_TOP_K=3

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Enable rich terminal formatting
ENABLE_RICH_CONSOLE=true

# =============================================================================
# CLICKHOUSE CONFIGURATION (Optional - for FAQ system)
# =============================================================================

# ClickHouse server host (leave empty if not using FAQs)
CLICKHOUSE_HOST=

# ClickHouse server port
CLICKHOUSE_PORT=8123

# ClickHouse database name
CLICKHOUSE_DB_NAME=
